{
  "name": "@beeve/auth",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "srvx serve --prod --dir . --entry ./dist/server/server.js --static ./dist/client",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "biome lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .output .turbo",
    "auth:schema:generate": "npx auth@latest generate --config src/lib/auth/server.ts --output src/lib/auth/schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@beeve/ui": "workspace:*",
    "@better-auth/drizzle-adapter": "^1.5.5",
    "@elysiajs/cors": "1.4.1",
    "@elysiajs/eden": "1.4.8",
    "@sinclair/typebox": "0.34.48",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.1",
    "@tanstack/solid-router": "^1.168.1",
    "@tanstack/solid-start": "1.167.1",
    "better-auth": "1.5.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "elysia": "1.4.28",
    "lucide-solid": "^0.577.0",
    "openapi-types": "12.1.3",
    "pg": "8.20.0",
    "solid-js": "^1.9.11",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/pg": "^8.11.11",
    "typescript": "^5.7.2",
    "vite": "^8.0.1",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.0"
  }
}
