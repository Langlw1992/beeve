{
  "name": "@beeve/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./auth": "./src/auth.ts",
    "./db": "./src/db/schema.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "better-auth": "^1.5.4",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.7.2"
  }
}
