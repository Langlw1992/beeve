{
  "name": "@beeve/ui",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/source/index.js",
  "module": "./dist/source/index.js",
  "types": "./dist/types/index.d.ts",
  "files": ["dist", "src"],
  "sideEffects": ["./src/styles/index.css", "./dist/styles.css"],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "solid": "./src/index.ts",
      "default": "./dist/source/index.js"
    },
    "./themes": {
      "types": "./dist/types/themes/index.d.ts",
      "solid": "./src/themes/index.ts",
      "default": "./dist/source/themes/index.js"
    },
    "./providers": {
      "types": "./dist/types/providers/index.d.ts",
      "solid": "./src/providers/index.ts",
      "default": "./dist/source/providers/index.js"
    },
    "./components/*": {
      "types": "./dist/types/components/*/index.d.ts",
      "solid": "./src/components/*/index.ts",
      "default": "./dist/source/components/*/index.js"
    },
    "./styles": {
      "solid": "./src/styles/index.css",
      "default": "./dist/styles.css"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.source.json --watch",
    "build": "pnpm clean && pnpm build:source && pnpm build:types && pnpm build:styles",
    "build:source": "tsc -p tsconfig.source.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:styles": "node ./scripts/build-styles.mjs",
    "lint": "biome lint ./src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "@tanstack/solid-form": "^1.28.5",
    "@tanstack/solid-table": "^8.21.3",
    "@zag-js/collapsible": "^1.37.0",
    "@zag-js/combobox": "^1.37.0",
    "@zag-js/date-picker": "^1.37.0",
    "@zag-js/dialog": "^1.37.0",
    "@zag-js/hover-card": "^1.37.0",
    "@zag-js/menu": "^1.37.0",
    "@zag-js/navigation-menu": "^1.37.0",
    "@zag-js/popover": "^1.37.0",
    "@zag-js/presence": "^1.37.0",
    "@zag-js/select": "^1.37.0",
    "@zag-js/slider": "^1.37.0",
    "@zag-js/solid": "^1.37.0",
    "@zag-js/tabs": "^1.37.0",
    "@zag-js/toast": "^1.37.0",
    "@zag-js/tooltip": "^1.37.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.1",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.11",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.0"
  }
}
